<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
  <title>Organizer Dashboard</title>
</head>

<body class="bg-light">
  <nav class="navbar navbar-dark bg-dark mb-4">
    <span class="navbar-brand mb-0 h1">Welcome, <%= user.name %> (Organizer)</span>
    <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
  </nav>

  <div class="container">
    <div class="card mb-5 shadow-sm">
      <div class="card-header bg-success text-white">
        <h4 class="mb-0">Add New Event</h4>
      </div>
      <div class="card-body">
        <form action="/organizer/event/add" method="POST">
          <div class="form-row">
            <div class="form-group col-md-4">
              <label>Event Name</label>
              <input type="text" name="name" class="form-control" placeholder="e.g. Event 1" required>
            </div>
            <div class="form-group col-md-12 mb-3">
              <label><strong>Select Weekdays:</strong></label><br>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="weekdays" value="monday">
                <label class="form-check-label">Monday</label>
              </div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="weekdays" value="tuesday">
                <label class="form-check-label">Tuesday</label>
              </div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="weekdays" value="wednesday">
                <label class="form-check-label">Wednesday</label>
              </div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="weekdays" value="thursday">
                <label class="form-check-label">Thursday</label>
              </div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="weekdays" value="friday">
                <label class="form-check-label">Friday</label>
              </div>
            </div>
            <div class="form-group col-md-4">
              <label>Time</label>
              <input type="text" name="time" class="form-control" placeholder="e.g. 9am" required>
            </div>
          </div>
          <button type="submit" class="btn btn-success px-4">Create Event</button>
        </form>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6">
        <h4 class="text-primary">My Events</h4>
        <hr>
        <% if(myEvents.length> 0) { %>
          <% myEvents.forEach(function(event) { %>
            <div class="card mb-3 border-primary">
              <div class="card-body">
                <h5 class="card-title">
                  <%= event.name %>
                </h5>
                <p class="mb-1"><strong>Day:</strong>
                  <%= event.weekdays %>
                </p>
                <p class="mb-0"><strong>Time:</strong>
                  <%= event.time %>
                </p>
              </div>
            </div>
            <% }) %>
              <% } else { %>
                <div class="alert alert-warning">You haven't added any events yet.</div>
                <% } %>
      </div>

      <div class="col-md-6">
        <h4 class="text-secondary">Other Organizers' Events</h4>
        <hr>
        <% if(otherEvents.length> 0) { %>
          <% otherEvents.forEach(function(event) { %>
            <div class="card mb-3 bg-white">
              <div class="card-body text-muted">
                <h5 class="card-title">
                  <%= event.name %> <small>(by <%= event.organizer.name %>)</small>
                </h5>
                <p class="mb-1"><strong>Day:</strong>
                  <%= event.weekdays %>
                </p>
                <p class="mb-0"><strong>Time:</strong>
                  <%= event.time %>
                </p>
              </div>
            </div>
            <% }) %>
              <% } else { %>
                <div class="alert alert-secondary">No other events available.</div>
                <% } %>
      </div>
    </div>
  </div>
</body>

</html>